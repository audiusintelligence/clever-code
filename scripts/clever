#!/usr/bin/env bash
# clever - Clever Solution CLI
# Wrapper. Die meiste Arbeit macht opencode + die Guides in ~/.clever/guides/
set -euo pipefail

CLEVER_HOME="${CLEVER_HOME:-$HOME/.clever}"

case "${1:-help}" in
  auth)
    bash "$CLEVER_HOME/scripts/keycloak-client.sh" auth
    ;;
  check)
    shift
    bash "$CLEVER_HOME/scripts/check-slug.sh" "$@"
    ;;
  invite)
    shift
    bash "$CLEVER_HOME/scripts/keycloak-client.sh" invite "$@"
    ;;
  list)
    if [ -d "$CLEVER_HOME/solutions" ] && [ -n "$(ls -A $CLEVER_HOME/solutions 2>/dev/null)" ]; then
      ls -1 "$CLEVER_HOME/solutions/"
    else
      echo "Noch keine Solutions. Anlegen: opencode \"neue Solution my-app\""
    fi
    ;;
  new)
    shift
    SLUG="${1:-}"
    if [[ -z "$SLUG" ]]; then
      echo "Usage: clever new <slug> [beschreibung]"
      exit 1
    fi

    # Recursion-Schutz: nicht von innerhalb opencode 'clever new' erneut aufrufen
    if [[ -n "${OPENCODE_SESSION_ID:-}${OPENCODE_AGENT:-}" ]]; then
      echo "✗ Du bist bereits in einer opencode-Session."
      echo "  Bitte Slash-Command nutzen: /new-solution $*"
      exit 1
    fi

    bash "$CLEVER_HOME/scripts/check-slug.sh" "$SLUG" || exit 1

    if ! command -v opencode >/dev/null 2>&1; then
      echo "✗ opencode nicht installiert. Installation:"
      echo "  curl -fsSL https://opencode.ai/install | bash"
      exit 1
    fi

    # opencode mit korrektem 'run' Subkommando und expliziter Agent-Auswahl
    DESC="${*:2}"
    PROMPT="Erstelle eine neue Clever Solution namens '$SLUG'"
    [[ -n "$DESC" ]] && PROMPT="$PROMPT für: $DESC"
    PROMPT="$PROMPT. Folge strikt dem clever-solution Agent und den Guides in ~/.clever/guides/."
    exec opencode run --agent clever-solution "$PROMPT"
    ;;

  deploy)
    shift
    NAME="${1:-}"
    [[ -z "$NAME" ]] && { echo "Usage: clever deploy <slug>"; exit 1; }

    # Loop-Schutz: deploy.sh darf nicht 'clever deploy' aufrufen
    if [[ "${CLEVER_DEPLOY_RUNNING:-}" == "1" ]]; then
      echo "✗ Endlosschleife erkannt: deploy.sh ruft 'clever deploy' rekursiv auf."
      echo "  Bitte ${CLEVER_HOME}/solutions/${NAME}/deploy/deploy.sh anpassen -"
      echo "  direkt 'docker compose ...' / 'rsync ...' nutzen, nicht 'clever deploy'."
      exit 1
    fi
    export CLEVER_DEPLOY_RUNNING=1

    SOLDIR="$CLEVER_HOME/solutions/$NAME"
    [[ ! -d "$SOLDIR" ]] && { echo "✗ Solution '$NAME' existiert nicht in $SOLDIR"; exit 1; }

    if [[ -f "$SOLDIR/deploy/deploy.sh" ]]; then
      cd "$SOLDIR" && bash deploy/deploy.sh "${@:2}"
    else
      echo "Kein deploy/deploy.sh vorhanden."
      echo "  Lass opencode eines generieren oder schreibe es manuell."
      echo "  Pfad: $SOLDIR/deploy/deploy.sh"
      echo
      echo "  Es darf NICHT 'clever deploy' aufrufen, sondern direkt:"
      echo "    rsync -av . user@host2.audius.local:/srv/clevercompany/solutions/$NAME/"
      echo "    ssh user@host2.audius.local 'cd /srv/clevercompany/solutions/$NAME && docker compose up -d --build'"
      exit 1
    fi
    ;;
  update)
    echo "→ Update Guides und Scripts..."
    curl -fsSL "${CLEVER_INSTALLER_BASE:-https://code.clevercompany.ai}/install" | bash
    ;;
  help|--help|-h|"")
    cat <<EOF
clever - Clever Solution CLI

USAGE:
  clever auth                    Keycloak Admin Login (einmalig pro 5 min)
  clever check <slug>            Prüfe ob Slug/Subdomain verfügbar
  clever new <name>              Erstelle Solution (ruft opencode)
  clever invite <name> <email>   User für Solution freischalten
  clever list                    Alle eigenen Solutions
  clever deploy <name>           Solution deployen
  clever update                  Guides + Scripts aktualisieren

ERSTE SCHRITTE (Mac, von 0):
  1. brew install --cask docker          (falls nicht da)
  2. curl -fsSL https://opencode.ai/install | bash
  3. curl -fsSL https://code.clevercompany.ai/install | bash
  4. clever auth
  5. clever new my-first-solution

DOKUMENTATION:
  ~/.clever/guides/                # alle Guides
  https://code.clevercompany.ai    # online
EOF
    ;;
  *)
    echo "Unbekannt: $1 (versuche 'clever help')"
    exit 1
    ;;
esac
